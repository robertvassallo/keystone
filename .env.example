# Root-level env example. Copy to `.env` and fill values.
# `.env` is gitignored; never commit real secrets.
#
# In production, secrets come from the chosen secret manager (see
# docs/01_architecture/security.md), not from a checked-in file.

# ───────── Project ─────────
PROJECT_NAME=rlv-platform
NODE_ENV=development
DJANGO_SETTINGS_MODULE=config.settings.dev

# ───────── Database (Postgres) ─────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=rlv_platform_dev
POSTGRES_USER=rlv_platform
POSTGRES_PASSWORD=
DATABASE_URL=postgresql://rlv_platform:@localhost:5432/rlv_platform_dev

# ───────── Cache / queue (Redis) ─────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ───────── Django ─────────
# Generate with `python -c "import secrets; print(secrets.token_urlsafe(50))"`
DJANGO_SECRET_KEY=
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DJANGO_DEBUG=true

# CSRF + session cookies (prod sets these via prod.py)
SESSION_COOKIE_SECURE=false
CSRF_COOKIE_SECURE=false

# ───────── Next.js ─────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ───────── Email (dev: console; prod: SMTP / SES / Postmark) ─────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_FROM=noreply@example.com
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=

# ───────── Auth (when OIDC / SSO lands) ─────────
# OIDC_ISSUER_URL=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=

# ───────── Observability ─────────
LOG_LEVEL=INFO
LOG_FORMAT=json
SENTRY_DSN=

# ───────── Storage (when file uploads land) ─────────
# STORAGE_BACKEND=local
# AWS_S3_BUCKET=
# AWS_S3_REGION=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ───────── Feature flags / kill switches ─────────
# ENABLE_FEATURE_X=false
